# ── Frontend local dev overrides ─────────────────────────────────────────────
#
# Copy this file to frontend/.env.local (git-ignored).
# Vite loads .env.local automatically in dev mode.
#
# These settings let you bypass Foundry's Compute Module layer and hit
# the FastAPI backend directly — useful when testing locally without a
# full Foundry deployment.
# ─────────────────────────────────────────────────────────────────────────────

# When set, streamChat() POSTs to this URL instead of the Foundry CM endpoint.
# Set to your local backend address when running docker compose up or bare Python.
VITE_DIRECT_BACKEND_URL=http://localhost:8080

# ── Lobster Backend — Environment Variables ───────────────────────────────────
#
# Copy this file to backend/.env and fill in your values.
# All settings have defaults — only the ones marked REQUIRED need changing.
#
# Pydantic-settings loads these in order of priority:
#   1. OS environment variables (highest — docker-compose environment: block)
#   2. This .env file
#   3. Defaults in config.py (lowest)
# ─────────────────────────────────────────────────────────────────────────────


# ── Foundry connection ────────────────────────────────────────────────────────

# REQUIRED: Your Foundry instance URL (no trailing slash).
FOUNDRY_URL=https://accenture.palantirfoundry.com

# REQUIRED for LLM calls: A valid Foundry personal access token.
# In production, this is injected automatically by the CM runtime as MODULE_AUTH_TOKEN.
# For local dev, set this to your personal token from:
#   Foundry > Account Settings > Developer Settings > Personal Access Tokens
#
# Note: For /chat requests the per-user token (from the CM function call) is used.
# This token is only needed for the LLM passthrough route (/llm/proxy/openai/v1/*)
# and ontology writes — i.e., it sets the MODULE_AUTH_TOKEN fallback.
MODULE_AUTH_TOKEN=your-foundry-personal-token-here


# ── LLM Proxy ─────────────────────────────────────────────────────────────────

# Foundry OpenAI-compatible LLM proxy path (used when USE_OPENCLAW_GATEWAY=false)
LLM_PROXY_PATH=/api/v2/llm/proxy/openai/v1/chat/completions

# Foundry openai-compatible LLM proxy path (used by OpenClaw passthrough route)
LLM_PROXY_openai_PATH=/api/v2/llm/proxy/openai/v1

# Default model short name (as configured in Foundry Developer Console > Language Models)
DEFAULT_MODEL=claude-3-5-sonnet

# Set true if Foundry does not have the native openai endpoint.
# When true, the passthrough route translates openai-format requests to OpenAI format.
LLM_PROXY_openai_TRANSLATE=false


# ── Feature flags ─────────────────────────────────────────────────────────────

# false → direct Foundry LLM proxy call (simple, default for local dev)
# true  → route through OpenClaw WS gateway (requires openclaw process running)
USE_OPENCLAW_GATEWAY=false


# ── OpenClaw gateway (only relevant if USE_OPENCLAW_GATEWAY=true) ─────────────

# The port OpenClaw listens on inside the container (matches supervisord.conf)
OPENCLAW_PORT=18789

# Authentication token OpenClaw requires for operator connections.
# Must match the token OpenClaw was started with (OPENCLAW_GATEWAY_TOKEN env var).
# In Foundry production, set this via Foundry Secrets (not hardcoded).
OPENCLAW_GATEWAY_TOKEN=local-dev-secret


# ── CORS (local dev only) ─────────────────────────────────────────────────────

# Comma-separated list of allowed origins for CORS.
# Set to http://localhost:5173 for local Vite dev server.
# Leave empty in production — the frontend doesn't call FastAPI directly.
CORS_ORIGINS=http://localhost:5173
